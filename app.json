{
  "expo": {
    "name": "CatatOmset",
    "slug": "catat-omset",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#071018",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#071018"
    },
    "android": {
      "package": "com.trackeromset.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#071018"
      }
    },
    "plugins": [
      "expo-sqlite",
      "expo-asset",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "1d46ebb3-7c26-4bce-9319-652e81462008"
      }
    },
    "owner": "aliangkoko"
  }
}