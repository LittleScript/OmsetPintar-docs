{
  "expo": {
    "name": "Omset Pintar",
    "slug": "omset-pintar",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#071018",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#071018"
    },
    "android": {
      "package": "com.omsetpintar.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "plugins": [
      "expo-sqlite",
      "expo-asset",
      "@react-native-community/datetimepicker",
      "expo-local-authentication",
      "expo-secure-store",
      "expo-notifications"
    ],
    "owner": "littlescript",
    "extra": {
      "eas": {
        "projectId": "55b614cd-0a08-43c6-998c-75bdbfd8e923"
      }
    },
    "scheme": "com.omsetpintar.app"
  }
}